# Environment variables — copy to .env.local and fill in your values.
# Never commit .env.local to source control.

# Base URL of the backend API (include scheme, host and port, no trailing slash)
VITE_API_BASE_URL=https://localhost:7000

# Set to "true" to enable the dev-login bypass (disable in production)
VITE_ENABLE_DEV_LOGIN=false

# Set to "true" only when the SignalR /hubs/notifications endpoint is deployed
VITE_ENABLE_SIGNALR=false
